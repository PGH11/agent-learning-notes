# 复制为 .env 后填写真实值（.env 已被 .gitignore 忽略，勿提交）

# 火山 Ark / OpenAI 兼容接口（必填，用于 LLM）
ARK_API_KEY=
ARK_MODEL=ark-code-latest
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3

# LitMedia 文生视频 / 图生视频（调用工具节点时必填）
LITMEDIA_TOKEN=
LITMEDIA_API_SECRET=
LITMEDIA_DEVICE_CODE=

# LangSmith 可观测性（可选）
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# 调试与 RAG（可选）
# DEBUG_AI_OUTPUT=1
# RAG_TOP_K=3
# RAG_CHUNK_MAX_CHARS=900
